modules = ["java-graalvm22.3"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["fontconfig", "dejavu_fonts", "freetype", "xorg.libX11", "xorg.libXext", "xorg.libXrender", "xorg.libXtst", "xorg.libXi"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "EdeGen"

[[workflows.workflow]]
name = "EdeGen"
author = "agent"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && if [ ! -f /tmp/jdk-25.0.2/bin/javac ]; then echo \"Installing JDK 25...\" && cd /tmp && curl -sL \"https://download.java.net/java/GA/jdk25.0.2/b1e0dfa218384cb9959bdcb897162d4e/10/GPL/openjdk-25.0.2_linux-x64_bin.tar.gz\" -o jdk25.tar.gz && tar xzf jdk25.tar.gz && rm jdk25.tar.gz && cd /home/runner/workspace; fi && export JAVA_HOME=/tmp/jdk-25.0.2 && export PATH=$JAVA_HOME/bin:$PATH && echo \"Building EdeStl submodule...\" && cd lib/EdeStl && mkdir -p bin tmp lib && if [ ! -f lib/asm-9.6.jar ]; then curl -sL \"https://repo1.maven.org/maven2/org/ow2/asm/asm/9.6/asm-9.6.jar\" -o lib/asm-9.6.jar; fi && find src -type f -name \"*.java\" ! -name \"#*\" ! -name \"*~\" > build/BuildList.txt && javac -cp \"lib/*\" \"@build/BuildList.txt\" -sourcepath \"./src\" -d \"tmp\" -encoding \"UTF-8\" && for lib_jar in lib/*.jar; do if [ -f \"$lib_jar\" ]; then (cd tmp && jar xf \"../$lib_jar\"); fi; done && jar cf \"./bin/EdeStl.jar\" -C \"./tmp\" \".\" && rm -rf tmp/* && echo \"Built EdeStl.jar\" && cd /home/runner/workspace && mkdir -p bin && find src -type f -name \"*.java\" ! -name \"#*\" ! -name \"*~\" > build/BuildList.txt && javac -cp \"lib/EdeStl/bin/EdeStl.jar\" @build/BuildList.txt -sourcepath \"./src\" -d \"./bin\" -encoding \"UTF-8\" && java -Dsun.awt.fontconfig=/home/runner/workspace/fontconfig.properties -cp \"bin:lib/EdeStl/bin/EdeStl.jar\" ede.gen.driver.EdeGenerator"
